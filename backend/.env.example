# ────────────────────────────────────────────────────────────────
# Route Memory Platform — Environment Variables
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# Variables marked REQUIRED have no default — the app will
# refuse to start until they are set.
# ────────────────────────────────────────────────────────────────

# ── Runtime ───────────────────────────────────────────────────
# Application environment: development | production | test
NODE_ENV=development

# Port the HTTP server listens on
PORT=3000

# Frontend origin used for CORS (production). Leave empty in dev; localhost:5173 is always allowed.
CLIENT_URL=http://localhost:5173

# ── MongoDB ───────────────────────────────────────────────────
# Full MongoDB connection URI.
# For Docker Compose: use "mongo" as the hostname (service name).
# For local dev: use localhost.
MONGODB_URI=mongodb://localhost:27017/route_memory

# Time (ms) the MongoDB driver waits to find an available server
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000

# Time (ms) before an idle socket is closed
MONGODB_SOCKET_TIMEOUT_MS=45000

# ── Redis ─────────────────────────────────────────────────────
# Redis connection URL. Used by Bull queue and cache layer.
# For Docker Compose: use "redis" as the hostname (service name).
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────────
# REQUIRED — no default, must be set
# Secret used to sign short-lived access tokens. Must be at least 32 characters.
JWT_ACCESS_SECRET=

# REQUIRED — no default, must be set
# Secret used to sign long-lived refresh tokens. Must be at least 32 characters.
JWT_REFRESH_SECRET=

# Access token lifetime (e.g. 15m, 1h). Default: 15m
JWT_ACCESS_EXPIRY=15m

# Refresh token lifetime (e.g. 7d, 30d). Default: 7d
JWT_REFRESH_EXPIRY=7d

# ── GPS / Spatial ─────────────────────────────────────────────
# Maximum allowed distance (metres) between consecutive GPS points.
# Any jump exceeding this threshold is silently rejected as noise.
GPS_JUMP_THRESHOLD_METERS=500

# Minimum number of valid coordinates required for a route to be
# marked "completed". Routes below this threshold are "abandoned".
ROUTE_MIN_COORDINATES=3

# ── Cache TTLs ────────────────────────────────────────────────
# Heatmap cache time-to-live in seconds (default: 300 = 5 minutes)
HEATMAP_CACHE_TTL_SECONDS=300

# Suggestion cache time-to-live in seconds (default: 600 = 10 minutes)
SUGGESTION_CACHE_TTL_SECONDS=600

# ── Bull Queue ────────────────────────────────────────────────
# Number of concurrent routeWriter workers processing GPS writes
BULL_CONCURRENCY=5
