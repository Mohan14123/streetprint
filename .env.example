# ───────────────────────────────────────────────
# Route Memory Platform — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ───────────────────────────────────────────────

NODE_ENV=development
PORT=3000

# ── MongoDB ──────────────────────────────────────
# Required. Must be a full MongoDB connection URI.
MONGODB_URI=mongodb://localhost:27017/route_memory

# MongoDB timeout tuning (milliseconds)
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000
MONGODB_SOCKET_TIMEOUT_MS=45000

# ── Redis ─────────────────────────────────────────
# Required for queue (Bull) and caching.
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────
# Must be at least 32 characters each.
JWT_ACCESS_SECRET=change_me_at_least_32_chars_long_access
JWT_REFRESH_SECRET=change_me_at_least_32_chars_long_refresh
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── GPS / Spatial ─────────────────────────────────
# Max allowed jump between consecutive GPS points (metres).
GPS_JUMP_THRESHOLD_METERS=500

# Minimum coordinate count for a route to be saved as "completed".
ROUTE_MIN_COORDINATES=3

# ── Cache TTLs ────────────────────────────────────
# Heatmap cache TTL in seconds (default 5 minutes).
HEATMAP_CACHE_TTL_SECONDS=300

# Suggestion cache TTL in seconds (default 10 minutes).
SUGGESTION_CACHE_TTL_SECONDS=600

# ── Bull Queue ────────────────────────────────────
# Number of concurrent routeWriter workers.
BULL_CONCURRENCY=5
